{
  "name": "notepad",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:vercel": "vercel dev",
    "build:solid": "tsc -b && vite build",
    "deploy:vercel": "vercel --prod",
    "env:pull": "vercel env pull",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "lint": "eslint",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,scss,less}": [
      "prettier --write"
    ],
    "*.{json,md,mdx,html,xml,yml,yaml}": [
      "prettier --write"
    ]
  },
  "prettier": {
    "plugins": [
      "prettier-plugin-tailwindcss"
    ]
  },
  "dependencies": {
    "@tailwindcss/vite": "4.3.0",
    "dexie": "^4.4.2",
    "solid-js": "^1.9.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@openrouter/sdk": "^0.12.35",
    "@types/node": "^25.8.0",
    "@vercel/node": "^5.8.2",
    "autoprefixer": "^10.5.0",
    "daisyui": "^5.5.19",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "postcss": "^8.5.14",
    "prettier": "3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.3",
    "vercel": "^54.1.0",
    "vite": "^8.0.13",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plugin-solid": "^2.11.12"
  }
}
