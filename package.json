{
  "name": "notepad",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:vercel": "vercel dev",
    "build:solid": "tsc -b && vite build",
    "deploy:vercel": "vercel --prod",
    "env:pull": "vercel env pull",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "lint": "eslint",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,scss,less}": [
      "prettier --write"
    ],
    "*.{json,md,mdx,html,xml,yml,yaml}": [
      "prettier --write"
    ]
  },
  "prettier": {
    "plugins": [
      "prettier-plugin-tailwindcss"
    ]
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "dexie": "^4.3.0",
    "solid-js": "^1.9.11"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@openrouter/sdk": "^0.9.11",
    "@types/node": "^25.5.0",
    "@vercel/node": "^5.6.18",
    "autoprefixer": "^10.4.27",
    "daisyui": "^5.5.19",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.8",
    "prettier": "3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.57.2",
    "vercel": "^50.35.0",
    "vite": "^8.0.2",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-solid": "^2.11.11"
  }
}
